rules_version = '2';

// PNC UNIQUE LTD — Contractor Induction Portal
// Firestore Security Rules
//
// Model:
//   * The FastAPI backend uses the Firebase Admin SDK, which bypasses these
//     rules entirely. All reads/writes on production data go through the
//     backend, where they are authenticated (invitee access-code check for
//     the induction endpoints; HTTP Basic Auth for admin endpoints) and
//     logged in Cloud Run.
//   * The browser never reads or writes Firestore directly. Storage uploads
//     from the browser remain (see storage.rules) but the download URLs are
//     minted server-side.
//
// Therefore this ruleset is deny-by-default for every collection.

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny every direct client access. Backend Admin SDK bypasses rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
