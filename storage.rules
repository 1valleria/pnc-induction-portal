rules_version = '2';

// PNC Induction Portal — Cloud Storage security rules
//
// Inductees upload identity documents and signatures directly from the
// browser via the Firebase Web SDK. Reads are open so the confirmation
// screen can show thumbnails.

service firebase.storage {
  match /b/{bucket}/o {
    match /employees/{employeeId}/{allPaths=**} {
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)|application/pdf');
      allow read: if true;
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
